# ═══════════════════════════════════════════════════
# CREOVA GROWTH AGENT — Environment Configuration
# ═══════════════════════════════════════════════════
# INTERNAL USE ONLY — NOT FOR USERS

# ─── AI ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=dall-e-3

# ─── DATABASE ────────────────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
DATABASE_URL=postgresql://postgres:...@db.xxx.supabase.co:5432/postgres

# ─── REDIS (BullMQ Queue) ────────────────────────────
REDIS_URL=redis://localhost:6379
# Or Upstash:
# REDIS_URL=rediss://default:...@...upstash.io:6380

# ─── TWITTER / X ─────────────────────────────────────
X_API_KEY=...
X_API_SECRET=...
X_ACCESS_TOKEN=...
X_ACCESS_SECRET=...
X_BEARER_TOKEN=...

# ─── INSTAGRAM (Meta Graph API) ──────────────────────
INSTAGRAM_ACCESS_TOKEN=...
INSTAGRAM_ACCOUNT_ID=...
META_APP_ID=...
META_APP_SECRET=...

# ─── STORAGE (Cloudflare R2) ─────────────────────────
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=creova-agent-assets
R2_PUBLIC_URL=https://assets.creovas.studio

# ─── AGENT CONFIG ────────────────────────────────────
AGENT_TIMEZONE=Asia/Kolkata
AGENT_DAILY_POST_LIMIT=3
AGENT_MIN_QUALITY_SCORE=75
AGENT_BRAND_NAME=Creova Studio
AGENT_WEBSITE_URL=https://creovas.studio
AGENT_TARGET_AUDIENCE=AI founders, indie hackers, creators, startups

# ─── NOTIFICATIONS ───────────────────────────────────
# Optional: get Telegram alerts when agent posts
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# ─── GITHUB (for auto feature detection) ─────────────
GITHUB_TOKEN=...
GITHUB_REPO=arun952137-afk/viralforge-ai

# ─── ENVIRONMENT ─────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
